# Database
DATABASE_URL=sqlite:///./generate_pic.db

# Jimeng image generation provider
JIMENG_API_BASE_URL=
JIMENG_API_KEY=
JIMENG_MODEL=
JIMENG_GENERATE_ENDPOINT=/generate
JIMENG_TASK_STATUS_ENDPOINT=/tasks/{task_id}
JIMENG_TIMEOUT_SECONDS=180
JIMENG_POLL_INTERVAL_SECONDS=3
JIMENG_SAVE_DIR=uploads/images
